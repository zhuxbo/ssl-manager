# MySQL performance profile (~500-800MB)
# Suitable for: high-traffic deployments, dedicated servers with 4GB+ RAM, 100k+ orders
[mysqld]
innodb_buffer_pool_size = 512M
innodb_log_buffer_size = 16M
innodb_log_file_size = 128M
key_buffer_size = 32M
tmp_table_size = 64M
max_heap_table_size = 64M
max_connections = 150
table_open_cache = 1000
thread_cache_size = 16
sort_buffer_size = 2M
read_buffer_size = 1M
read_rnd_buffer_size = 1M
join_buffer_size = 1M
